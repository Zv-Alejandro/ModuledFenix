<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="root"
            prefHeight="850.0"
            prefWidth="1400.0"
            styleClass="game-root"
            stylesheets="@../styles/styles.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.ies.fenix.client.controller.GameControllerFx">

    <!-- TOP NAVBAR -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20.0"
              styleClass="content-container">

            <padding>
                <Insets top="30.0" right="30.0" bottom="0.0" left="30.0"/>
            </padding>

            <Button text="&lt;" styleClass="nav-button"/>
            <Button text="&gt;" styleClass="nav-button"/>

            <Label text="MARKET PLACE" styleClass="tab-inactive"/>
            <Label text="LIBRARY" styleClass="tab-active"/>
            <Label fx:id="usernameLabel"
                   text="USERNAME"
                   styleClass="tab-inactive"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Create your own visual novel"
                    styleClass="main-action-button"/>

            <HBox alignment="CENTER"
                  prefHeight="40.0"
                  prefWidth="40.0"
                  styleClass="profile-wrapper">

                <ImageView fitHeight="28.0"
                           fitWidth="28.0"
                           preserveRatio="true"
                           styleClass="profile-image"/>
            </HBox>

            <Label text="⌄" styleClass="dropdown-icon"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    styleClass="main-scroll">

            <content>
                <VBox spacing="0.0"
                      styleClass="game-container">

                    <!-- BIG BANNER -->
                    <HBox alignment="CENTER"
                          prefHeight="360.0"
                          styleClass="game-banner-wrapper">

                        <ImageView fitHeight="320.0"
                                   fitWidth="1200.0"
                                   preserveRatio="false"
                                   styleClass="game-banner-image"/>
                    </HBox>

                    <!-- LOWER CONTENT -->
                    <GridPane styleClass="game-main-grid"
                              hgap="0.0"
                              vgap="0.0">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="68.0"/>
                            <ColumnConstraints percentWidth="32.0"/>
                        </columnConstraints>

                        <!-- LEFT PANEL -->
                        <VBox GridPane.columnIndex="0"
                              spacing="24.0"
                              styleClass="game-left-panel">

                            <padding>
                                <Insets top="35.0"
                                        right="40.0"
                                        bottom="35.0"
                                        left="40.0"/>
                            </padding>

                            <Label text="GAME"
                                   styleClass="game-main-quote"/>

                            <VBox spacing="18.0">

                                <Label wrapText="true"
                                       styleClass="game-description"
                                       text="Lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est."/>

                                <Label wrapText="true"
                                       styleClass="game-description"
                                       text="Lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est."/>

                                <Label wrapText="true"
                                       styleClass="game-description"
                                       text="Lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est lorem ipsum est."/>

                            </VBox>
                        </VBox>

                        <!-- RIGHT PANEL -->
                        <VBox GridPane.columnIndex="1"
                              spacing="24.0"
                              styleClass="game-right-panel">

                            <padding>
                                <Insets top="35.0"
                                        right="40.0"
                                        bottom="35.0"
                                        left="40.0"/>
                            </padding>

                            <Label text="GAME"
                                   styleClass="game-title"/>

                            <!-- TAGS -->
                            <VBox spacing="10.0">

                                <HBox spacing="10.0">
                                    <Label text="Tag-1" styleClass="tag"/>
                                    <Label text="Tag-2" styleClass="tag"/>
                                    <Label text="Tag-3" styleClass="tag"/>
                                </HBox>

                                <HBox spacing="10.0">
                                    <Label text="Tag-4" styleClass="tag"/>
                                    <Label text="Tag-5" styleClass="tag"/>
                                </HBox>

                            </VBox>

                            <!-- INFO -->
                            <VBox spacing="14.0">

                                <Label text="Title: GAME"
                                       styleClass="game-info"/>

                                <Label text="Genre: Genre"
                                       styleClass="game-info"/>

                                <Label text="Developer: Developer"
                                       styleClass="game-info"/>

                            </VBox>

                            <!-- BUTTONS -->
                            <HBox spacing="18.0">

                                <Button text="Play"
                                        styleClass="game-play-button"/>

                                <Button text="Download"
                                        styleClass="game-download-button"/>

                            </HBox>

                        </VBox>

                    </GridPane>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>